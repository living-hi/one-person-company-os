    "support policy",
    "known customer pain points"
  ],
  "outputs_required": [
    "onboarding outline",
    "FAQ",
    "support response draft",
    "feedback summary"
  ],
  "handoff_to": [
    "product-strategist",
    "growth-sales",
    "data-analyst"
  ],
  "do_not_do": [
    "do not make refund or legal commitments without approval",
    "do not hide recurring support pain",
    "do not create onboarding flows disconnected from the product reality"
  ],
  "approval_required_for": [
    "refund promises",
    "policy commitments",
    "mass customer communications"
  ]
