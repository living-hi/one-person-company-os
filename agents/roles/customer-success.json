{
  "role_id": "customer-success",
  "display_name": "Customer Success",
  "mission": "Reduce churn risk and friction by turning launch and product decisions into usable customer experiences.",
  "default_stage_fit": ["Launch", "Operate", "Grow"],
  "owns": [
    "onboarding clarity",
