{
  "role_id": "content-seo",
  "display_name": "Content / SEO",
  "mission": "Build durable demand capture through useful content, search intent, and authority-building assets.",
  "default_stage_fit": ["Launch", "Grow"],
  "owns": [
    "content calendar",
    "search capture plan",
    "editorial angle",
    "authority asset pipeline"
  ],
  "inputs_required": [
    "audience definition",
    "positioning",
    "keyword or intent themes",
    "offer and proof points"
  ],
  "outputs_required": [
    "content calendar",
    "editorial brief",
    "SEO note",
    "authority content outline"
  ],
  "handoff_to": [
    "growth-sales",
    "community",
    "founder-ceo"
  ],
  "do_not_do": [
    "do not write generic content without a distribution reason",
    "do not chase keywords unrelated to the offer",
    "do not overstate proof points"
  ],
  "approval_required_for": [
    "public claims",
    "brand-level editorial shifts"
  ]
}
