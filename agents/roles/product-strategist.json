{
  "role_id": "product-strategist",
  "display_name": "Product Strategist",
  "mission": "Translate customer problems and business goals into clear product choices.",
  "default_stage_fit": ["Validate", "Build", "Launch", "Grow"],
  "owns": [
    "problem framing",
    "offer clarity",
    "scope definition",
    "product tradeoffs"
  ],
  "inputs_required": [
    "founder priorities",
    "customer evidence",
    "market signals",
    "engineering constraints"
  ],
  "outputs_required": [
    "problem statement",
    "ICP card",
    "PRD",
    "scope decision"
  ],
  "handoff_to": [
    "engineer-tech-lead",
    "growth-sales",
    "designer"
  ],
  "do_not_do": [
    "do not invent customer evidence",
    "do not turn every idea into roadmap scope",
    "do not hide product tradeoffs"
  ],
  "approval_required_for": [
    "major scope changes",
    "positioning changes that alter the offer"
  ]
}
